  <script>
    const defaultConfig = {
      // Colors (5 max, ordered by visual prominence)
      background_color: '#FAF7F2',
      surface_color: '#FFFFFF',
      text_color: '#2C5545',
      primary_action_color: '#C45D3E',
      secondary_text_color: '#6B5E50',
      // Font
      font_family: 'Source Sans 3',
      font_size: 16,
      // Text content
      hero_name: 'Muskan',
      hero_title: 'Assistant Professor',
      profile_summary: 'Dedicated and passionate Assistant Professor with expertise in Computer Science and a strong commitment to academic excellence. Experienced in curriculum development, research supervision, and fostering an engaging learning environment. Published researcher with a focus on emerging technologies, machine learning, and data-driven solutions. Skilled in mentoring students, leading academic projects, and contributing to institutional growth through innovative teaching methodologies and interdisciplinary collaboration.',
      edu_1_degree: 'Ph.D. in Computer Science',
      edu_2_degree: 'M.Tech in Information Technology',
      edu_3_degree: 'B.Tech in Computer Science',
      exp_1_role: 'Assistant Professor',
      exp_2_role: 'Guest Lecturer',
      exp_3_role: 'Research Associate'
    };

    function applyConfig(config) {
      const c = { ...defaultConfig, ...config };
      const font = c.font_family || defaultConfig.font_family;
      const baseSize = c.font_size || defaultConfig.font_size;
      const bg = c.background_color || defaultConfig.background_color;
      const surface = c.surface_color || defaultConfig.surface_color;
      const text = c.text_color || defaultConfig.text_color;
      const action = c.primary_action_color || defaultConfig.primary_action_color;
      const secText = c.secondary_text_color || defaultConfig.secondary_text_color;

      // Background
      document.getElementById('app-wrapper').style.backgroundColor = bg;

      // Nav
      const nav = document.querySelector('nav');
      nav.style.background = bg + 'E6';
      document.getElementById('nav-name').style.color = text;
      document.querySelectorAll('.nav-link').forEach(el => { el.style.color = secText; el.style.setProperty('--underline', action); });

      // Hero
      document.getElementById('hero-name').textContent = c.hero_name;
      document.getElementById('hero-name').style.color = text;
      document.getElementById('hero-title').textContent = c.hero_title;
      document.getElementById('hero-title').style.color = secText;
      document.getElementById('avatar-initial').textContent = (c.hero_name || 'M')[0].toUpperCase();

      // Avatar gradient
      const avatarDiv = document.getElementById('avatar-initial').parentElement;
      avatarDiv.style.background = `linear-gradient(135deg, ${text}, ${text}CC)`;

      // Summary
      document.getElementById('profile-summary').textContent = c.profile_summary;
      document.getElementById('profile-summary').style.color = secText;

      // Education
      document.getElementById('edu-1').textContent = c.edu_1_degree;
      document.getElementById('edu-2').textContent = c.edu_2_degree;
      document.getElementById('edu-3').textContent = c.edu_3_degree;

      // Experience
      document.getElementById('exp-1').textContent = c.exp_1_role;
      document.getElementById('exp-2').textContent = c.exp_2_role;
      document.getElementById('exp-3').textContent = c.exp_3_role;

      // Cards surface color
      document.querySelectorAll('.card-hover').forEach(el => {
        if (!el.closest('#contact')) {
          el.style.backgroundColor = surface;
        }
      });

      // Section headings color
      document.querySelectorAll('.font-heading').forEach(el => {
        if (!el.closest('[style*="linear-gradient"]') && !el.closest('#contact')) {
          el.style.color = text;
        }
      });

      // Action color items
      document.querySelectorAll('[style*="color:#C45D3E"], [style*="background:#C45D3E"]').forEach(el => {
        if (el.style.color === 'rgb(196, 93, 62)') el.style.color = action;
        if (el.style.backgroundColor === 'rgb(196, 93, 62)') el.style.backgroundColor = action;
        if (el.style.background === 'rgb(196, 93, 62)') el.style.background = action;
      });

      // Timeline dots
      document.querySelectorAll('.timeline-dot').forEach(el => {
        el.style.borderColor = action;
        el.style.backgroundColor = bg;
      });

      // Icon badges with action color
      const actionBadges = document.querySelectorAll('[style*="background:#C45D3E"]');
      actionBadges.forEach(el => el.style.backgroundColor = action);

      // Date badges
      document.querySelectorAll('.tracking-wider').forEach(el => {
        if (!el.classList.contains('mb-2')) el.style.color = action;
      });

      // Font application
      const bodyStack = `${font}, 'Source Sans 3', sans-serif`;
      document.body.style.fontFamily = bodyStack;

      // Font sizing
      document.getElementById('hero-name').style.fontSize = `${baseSize * 3}px`;
      document.getElementById('hero-title').style.fontSize = `${baseSize * 1.25}px`;
      document.getElementById('profile-summary').style.fontSize = `${baseSize}px`;

      // Education heading font sizes
      document.querySelectorAll('#education-cards .font-heading').forEach(el => {
        el.style.fontSize = `${baseSize * 1.125}px`;
      });

      // Experience heading font sizes
      document.querySelectorAll('#experience-list .font-heading').forEach(el => {
        el.style.fontSize = `${baseSize * 1.125}px`;
      });

      // Contact section gradient
      const contactSection = document.querySelector('#contact .rounded-2xl');
      if (contactSection) {
        contactSection.style.background = `linear-gradient(135deg, ${text}, ${text}B3)`;
      }
    }

    // Element SDK init
    window.elementSdk.init({
      defaultConfig,
      onConfigChange: async (config) => {
        applyConfig(config);
      },
      mapToCapabilities: (config) => ({
        recolorables: [
          {
            get: () => config.background_color || defaultConfig.background_color,
            set: (v) => { config.background_color = v; window.elementSdk.setConfig({ background_color: v }); }
          },
          {
            get: () => config.surface_color || defaultConfig.surface_color,
            set: (v) => { config.surface_color = v; window.elementSdk.setConfig({ surface_color: v }); }
          },
          {
            get: () => config.text_color || defaultConfig.text_color,
            set: (v) => { config.text_color = v; window.elementSdk.setConfig({ text_color: v }); }
          },
          {
            get: () => config.primary_action_color || defaultConfig.primary_action_color,
            set: (v) => { config.primary_action_color = v; window.elementSdk.setConfig({ primary_action_color: v }); }
          },
          {
            get: () => config.secondary_text_color || defaultConfig.secondary_text_color,
            set: (v) => { config.secondary_text_color = v; window.elementSdk.setConfig({ secondary_text_color: v }); }
          }
        ],
        borderables: [],
        fontEditable: {
          get: () => config.font_family || defaultConfig.font_family,
          set: (v) => { config.font_family = v; window.elementSdk.setConfig({ font_family: v }); }
        },
        fontSizeable: {
          get: () => config.font_size || defaultConfig.font_size,
          set: (v) => { config.font_size = v; window.elementSdk.setConfig({ font_size: v }); }
        }
      }),
      mapToEditPanelValues: (config) => new Map([
        ['hero_name', config.hero_name || defaultConfig.hero_name],
        ['hero_title', config.hero_title || defaultConfig.hero_title],
        ['profile_summary', config.profile_summary || defaultConfig.profile_summary],
        ['edu_1_degree', config.edu_1_degree || defaultConfig.edu_1_degree],
        ['edu_2_degree', config.edu_2_degree || defaultConfig.edu_2_degree],
        ['edu_3_degree', config.edu_3_degree || defaultConfig.edu_3_degree],
        ['exp_1_role', config.exp_1_role || defaultConfig.exp_1_role],
        ['exp_2_role', config.exp_2_role || defaultConfig.exp_2_role],
        ['exp_3_role', config.exp_3_role || defaultConfig.exp_3_role]
      ])
    });

    // Smooth scrolling
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.querySelector(anchor.getAttribute('href'));
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    });

